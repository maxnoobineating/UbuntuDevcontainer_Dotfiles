FROM my-dev-image:latest

# Install ESP32 development tools
RUN apt-get update && apt-get install -y \
    build-essential \
    git \
    python3 \
    python3-pip \
    curl \
    wget \
    vim \
    nano \
    tmux \
    openssh-client

# Optional: ESP-IDF specific
RUN apt-get install -y \
    cmake \
    ninja-build \
    flex \
    bison \
    libglib2.0-0 \
    libpython3.9

# Clean up
RUN apt-get clean && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /workspace

# Keep container running
CMD ["/bin/bash"]
